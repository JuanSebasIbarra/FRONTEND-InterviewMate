# Backend base URL
# Local: http://localhost:8081
# Render: https://interviewmate-0-0-5-alpha.onrender.com
VITE_API_URL=http://localhost:8081

# Optional: if backend uses cookies/sessions cross-site
VITE_USE_CREDENTIALS=true

# OAuth2 (Google) start endpoint path in backend
VITE_GOOGLE_OAUTH_START_PATH=/auth/oauth2/google

# Google Gemini API key (used client-side for AI study context generation)
# ⚠️ Visible en el navegador — usar solo en desarrollo o con restricciones de dominio
VITE_AI_INTERVIEW_API_KEY=your_gemini_api_key_here

# Frontend path where the backend redirects after a successful OAuth2 sign-in.
# The backend's success redirect URI must be configured to point here:
#   <FRONTEND_URL>/auth/callback?token=<JWT>&expiresAt=<ISO>
# Change this only if you move the callback route in router.tsx.
VITE_OAUTH_CALLBACK_PATH=/auth/callback
